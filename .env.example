# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only — NEVER expose to client

# Line Login (for custom OAuth)
LINE_CHANNEL_ID=            # server-side only (used in /api/auth/callback)
LINE_CHANNEL_SECRET=        # server-side only
NEXT_PUBLIC_LINE_CHANNEL_ID=        # same value as LINE_CHANNEL_ID (exposed to browser for login button)
NEXT_PUBLIC_LINE_CALLBACK_URL=http://localhost:3000/api/auth/callback
